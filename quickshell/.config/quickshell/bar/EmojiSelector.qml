        var lower = searchText.toLowerCase();
        var ekeys = EmojiData.emojiNames;
        for (var ci = 0; ci < emojis.length; ci++) {
            var catLower = emojis[ci].cat.toLowerCase();
            for (var ei = 0; ei < emojis[ci].list.length; ei++) {
                var em = emojis[ci].list[ei];
                if (em.toLowerCase().includes(lower) || catLower.includes(lower)) {
                    results.push(em);
                } else if (ekeys && ekeys[em]) {
                    var kw = ekeys[em];
                    for (var ki = 0; ki < kw.length; ki++) {
                        if (kw[ki].includes(lower)) {
                            results.push(em);
                            break;
                        }
                    }
                }
            }
        }
        return results;
    }

    function insertEmoji(emoji) {
        Quickshell.execDetached(["sh", "-c", 'wl-copy "' + emoji + '" && wtype -M ctrl v && wtype -M shift Insert']);
        searchText = "";
        overlay.visible = false;
    }

    OverlayWindow {
        id: overlay

        Rectangle {
            id: emojiPopup
            implicitWidth: 380
            implicitHeight: 420
            radius: Theme.barRadius
            color: Theme.background
            anchors.centerIn: parent

            MouseArea {
                anchors.fill: parent
                onClicked: mouse => mouse.accepted = true
            }

            ColumnLayout {
                anchors.fill: parent
                anchors.margins: 8
                spacing: 6

                TextField {
                    id: searchField
                    Layout.fillWidth: true
                    height: 28
                    topPadding: 8; bottomPadding: 8; leftPadding: 8; rightPadding: 8
                    placeholderText: "Search emoji..."
                    color: Theme.fg
                    placeholderTextColor: Theme.fgMuted
                    font.pixelSize: 12
                    background: Rectangle { radius: 6; color: Theme.surface }
                    onTextChanged: root.searchText = text
                }

                RowLayout {
                    Layout.fillWidth: true
                    spacing: 3

                    Repeater {
                        model: root.emojis

                        delegate: Rectangle {
                            required property var modelData
                            required property int index

                            height: 24; width: 32; radius: 6
                            color: root.currentCat === modelData.cat ? Theme.accent : Theme.surface

                            Text { anchors.centerIn: parent; text: modelData.list[0]; font.pixelSize: 14 }

                            MouseArea {
                                anchors.fill: parent
                                cursorShape: Qt.PointingHandCursor
                                onClicked: {
                                    root.currentCat = modelData.cat;
                                    root.searchText = searchField.text;
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    Layout.fillWidth: true
                    Layout.fillHeight: true
                    radius: 6
                    color: Theme.surface
                    clip: true

                    Flickable {
                        anchors.fill: parent
                        anchors.margins: 4
                        contentHeight: grid.implicitHeight
                        contentWidth: grid.implicitWidth

                        Grid {
                            id: grid
                            columns: 8
                            spacing: 2

                            Repeater {
                                model: root.filteredList

                                delegate: Rectangle {
                                    required property var modelData

                                    width: 38; height: 38; radius: 6
                                    color: ma.containsMouse ? Theme.surfaceVariant : "transparent"

                                    Text { anchors.centerIn: parent; text: modelData; font.pixelSize: 22 }

                                    MouseArea {
                                        id: ma
                                        anchors.fill: parent
                                        hoverEnabled: true
                                        cursorShape: Qt.PointingHandCursor
                                        onClicked: root.insertEmoji(modelData)
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    GlobalShortcut {
        name: "quickshell:emoji-toggle"
        description: "Toggle Emoji Selector"
        onPressed: root.toggle()
    }

    function toggle() {
        overlay.visible = !overlay.visible;
        if (overlay.visible)
            searchField.forceActiveFocus();
    }
}
